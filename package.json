{
  "name": "platformos-tools",
  "version": "1.0.0",
  "description": "Developer tools for platformOS. Everything you need in one handy monorepo!",
  "main": "index.js",
  "repository": "https://github.com/Platform-OS/platformos-tools",
  "author": "platformOS",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "packages/platformos-common",
    "packages/lang-*",
    "packages/codemirror-language-client",
    "packages/liquid-html-parser",
    "packages/prettier-plugin-liquid",
    "packages/platformos-check-*",
    "packages/platformos-graph",
    "packages/platformos-language-server-*",
    "packages/vscode-extension",
    "packages/release-orchestrator"
  ],
  "scripts": {
    "admin:build": "sh ./scripts/dev-admin-build.sh",
    "admin:init": "sh ./scripts/dev-admin-init.sh",
    "build": "yarn workspaces run build",
    "build:ci": "yarn workspaces run build:ci",
    "build:ts": "yarn workspaces run build:ts",
    "dev:web": "yarn --cwd packages/vscode-extension dev:web",
    "format": "prettier --write \"packages/*/src/**/*.ts\"",
    "format:check": "prettier --check --ignore-unknown \"packages/*/src/**/*.ts\"",
    "playground": "yarn --cwd packages/codemirror-language-client run dev:playground",
    "prebuild:ts": "rm -rf packages/*/dist",
    "publish:vsce": "yarn --cwd packages/vscode-extension publish:vsce",
    "publish:ovsx": "yarn --cwd packages/vscode-extension publish:ovsx",
    "release": "yarn workspace release-orchestrator run start",
    "postrelease": "yarn --cwd packages/prettier-plugin-liquid prerelease",
    "reset": "find . -name \"node_modules\" -type d -prune -exec rm -rf '{}' +",
    "test": "vitest",
    "theme-check": "node packages/platformos-check-node/dist/cli.js",
    "type-check": "yarn workspaces run type-check"
  },
  "devDependencies": {
    "@changesets/cli": "^2.26.0",
    "copy-webpack-plugin": "^13.0.1",
    "css-loader": "^7.1.4",
    "html-webpack-plugin": "^5.6.6",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "typescript": "^5.9.0",
    "vitest": "^4.0.18",
    "vscode-languageserver-protocol": "^3.17.5",
    "vscode-languageserver-textdocument": "^1.0.12",
    "webpack": "^5.105.2",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.3"
  },
  "resolutions": {
    "minimatch": "^10.2.2",
    "lodash": "^4.17.23",
    "ajv": "^8.18.0",
    "diff": "^8.0.3",
    "qs": "^6.14.1",
    "@lezer/lr": "^1.4.8",
    "@lezer/highlight": "^1.2.3",
    "@lezer/common": "^1.5.1",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.15"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
