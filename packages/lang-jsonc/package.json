{
  "name": "@platformos/lang-jsonc",
  "version": "0.0.9",
  "description": "JSONC language support for CodeMirror",
  "publishConfig": {
    "access": "public",
    "@platformos:registry": "https://registry.npmjs.org"
  },
  "author": "platformOS",
  "homepage": "https://github.com/Platform-OS/platformos-tools/tree/master/packages/lang-jsonc#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Platform-OS/platformos-tools.git",
    "directory": "packages/lang-jsonc"
  },
  "bugs": {
    "url": "https://github.com/Platform-OS/platformos-tools/issues"
  },
  "main": "./dist/umd/index.js",
  "typings": "./dist/umd/index.js",
  "module": "./dist/esm/index.js",
  "exports": {
    "import": "./dist/esm/index.js",
    "require": "./dist/umd/index.js"
  },
  "license": "MIT",
  "devDependencies": {
    "@lezer/generator": "^1.8.0"
  },
  "dependencies": {
    "@lezer/highlight": "^1.2.3",
    "@lezer/lr": "^1.4.8"
  },
  "scripts": {
    "build": "yarn build:ts",
    "build:ci": "yarn build",
    "build:ts": "yarn build:esm && yarn build:umd",
    "build:esm": "tsc -b tsconfig.json",
    "build:umd": "tsc -b tsconfig.umd.json",
    "prebuild:esm": "yarn generate",
    "postbuild:esm": "cp src/parser.* dist/esm",
    "postbuild:umd": "cp src/parser.* dist/umd",
    "generate": "lezer-generator src/jsonc.grammar -o src/parser",
    "type-check": "tsc --noEmit",
    "test": "vitest"
  }
}
