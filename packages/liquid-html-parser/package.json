{
  "name": "@platformos/liquid-html-parser",
  "version": "0.0.7",
  "description": "Liquid HTML parser for platformOS",
  "author": "platformOS",
  "homepage": "https://github.com/Platform-OS/platformos-tools/tree/master/packages/liquid-html-parser#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Platform-OS/platformos-tools.git",
    "directory": "packages/liquid-html-parser"
  },
  "bugs": {
    "url": "https://github.com/Platform-OS/platformos-tools/issues"
  },
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "public",
    "@platformos:registry": "https://registry.npmjs.org"
  },
  "files": [
    "grammar/*",
    "dist/**/*.js",
    "dist/**/*.ts"
  ],
  "scripts": {
    "build": "yarn build:ts",
    "build:ci": "yarn build",
    "build:ts": "tsc -p tsconfig.build.json",
    "prebuild:ts": "node build/shims.js",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "line-column": "^1.0.2",
    "ohm-js": "^17.5.0"
  },
  "devDependencies": {
    "@types/line-column": "^1.0.2"
  }
}
