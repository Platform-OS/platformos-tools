{
  "objects": {
    "params":             { "replacement": "context.params", "note": "Always use context. prefix" },
    "authenticity_token": { "replacement": "context.authenticity_token", "note": "CSRF token for forms" },
    "locale":             { "replacement": "context.locale" },
    "page":               { "replacement": "context.page", "note": "page.title → context.page.metadata.title" },
    "request":            { "replacement": "context.location", "note": "request.path → context.location.path, request.host → context.location.host" },
    "current_user":       { "replacement": "context.current_user", "note": "Direct context property; nil if not authenticated" },
    "customer":           { "replacement": null, "note": "Use {% function current_user = 'modules/user/queries/user/current' %} then current_user.email, .id, .name" },
    "shop":               { "replacement": "context.constants", "note": "No direct equivalent — use context.constants.app_name or custom schema properties" },
    "cart":               { "replacement": null, "note": "No built-in cart — requires custom app/schema/cart.yml + GraphQL queries + session" },
    "product":            { "replacement": null, "note": "No built-in product — define app/schema/product.yml and use GraphQL queries" },
    "collection":         { "replacement": null, "note": "No built-in collection — define custom schema and use GraphQL queries" },
    "blog":               { "replacement": null, "note": "No built-in blog — define custom schema and use GraphQL queries" },
    "article":            { "replacement": null, "note": "No built-in article — define custom schema and use GraphQL queries" },
    "order":              { "replacement": null, "note": "No built-in order — define custom schema and use GraphQL queries" },
    "variant":            { "replacement": null, "note": "No built-in variant — define custom schema" },
    "paginate":           { "replacement": null, "note": "No built-in pagination — use context.params.page + GraphQL limit/offset + manual UI" },
    "search":             { "replacement": "context.params", "note": "search.terms → context.params.q" },
    "settings":           { "replacement": "context.constants", "note": "Or define custom schema properties" },
    "content_for_header": { "replacement": null, "note": "Use {% yield 'head' %} in layout for named head content blocks" },
    "canonical_url":      { "replacement": null, "note": "Build manually from context.location.url" },
    "page_title":         { "replacement": "context.page.metadata.title" },
    "template":           { "replacement": null, "note": "platformOS uses layouts set via page frontmatter" }
  },
  "filters": {
    "img_url":                   { "replacement": "asset_url", "note": "For static assets; for dynamic image resizing use external CDN or CSS" },
    "img_tag":                   { "replacement": null, "note": "Use standard HTML <img> tag" },
    "asset_img_url":             { "replacement": "asset_url" },
    "image_url":                 { "replacement": "asset_url" },
    "image_tag":                 { "replacement": null, "note": "Use standard HTML <img> tag" },
    "money":                     { "replacement": null, "note": "Format manually: value | divided_by: 100.0 | round: 2" },
    "money_with_currency":       { "replacement": null, "note": "Format manually" },
    "money_without_currency":    { "replacement": null, "note": "Format manually" },
    "money_without_trailing_zeros": { "replacement": null, "note": "Format manually" },
    "script_tag":                { "replacement": null, "note": "Use standard HTML: <script src=\"{{ 'file.js' | asset_url }}\"></script>" },
    "stylesheet_tag":            { "replacement": null, "note": "Use standard HTML: <link rel=\"stylesheet\" href=\"{{ 'file.css' | asset_url }}\">" },
    "link_to":                   { "replacement": null, "note": "Use standard HTML <a> tag" },
    "camelize":                  { "replacement": null, "note": "Not in platformOS" },
    "handleize":                 { "replacement": null, "note": "Not in platformOS — use downcase + replace for slug-like strings" },
    "hex_to_rgba":               { "replacement": null, "note": "Use CSS variables or calc()" },
    "color_to_rgb":              { "replacement": null, "note": "Use CSS color-mix() or CSS variables" },
    "color_to_hsl":              { "replacement": null, "note": "Use CSS color-mix() or CSS variables" },
    "color_darken":              { "replacement": null, "note": "Use CSS color-mix()" },
    "color_lighten":             { "replacement": null, "note": "Use CSS color-mix()" },
    "color_saturate":            { "replacement": null, "note": "Use CSS variables" },
    "color_desaturate":          { "replacement": null, "note": "Use CSS variables" },
    "color_mix":                 { "replacement": null, "note": "Use CSS color-mix()" },
    "color_contrast":            { "replacement": null, "note": "Use CSS variables" },
    "color_modify":              { "replacement": null, "note": "Use CSS variables" },
    "format_address":            { "replacement": null, "note": "Template the address fields manually" },
    "weight_with_unit":          { "replacement": null, "note": "Format manually" },
    "md5":                       { "replacement": null, "note": "Not in platformOS" },
    "sha1":                      { "replacement": null, "note": "Not in platformOS" },
    "hmac_sha1":                 { "replacement": null, "note": "Not in platformOS" },
    "product_img_url":           { "replacement": "asset_url" },
    "collection_img_url":        { "replacement": "asset_url" },
    "article_img_url":           { "replacement": "asset_url" },
    "default_pagination":        { "replacement": null, "note": "Use modules/common-styling/pagination partial" },
    "payment_type_img_url":      { "replacement": null, "note": "Not in platformOS" },
    "payment_type_svg_tag":      { "replacement": null, "note": "Not in platformOS" },
    "metafield_tag":             { "replacement": null, "note": "Use property() accessor in GraphQL" },
    "metafield_text":            { "replacement": null, "note": "Use property() accessor in GraphQL" },
    "placeholder_svg_tag":       { "replacement": null, "note": "Not in platformOS" },
    "customer_login_link":       { "replacement": null, "note": "Use standard <a href=\"/sessions/new\"> link" },
    "font_face":                 { "replacement": null, "note": "Use CSS @font-face" },
    "font_modify":               { "replacement": null, "note": "Use CSS variables" },
    "font_url":                  { "replacement": "asset_url", "note": "Use asset_url for font files" },
    "external_video_tag":        { "replacement": null, "note": "Use standard HTML <iframe> or <video>" },
    "external_video_url":        { "replacement": null, "note": "Build URL manually" },
    "video_tag":                 { "replacement": null, "note": "Use standard HTML <video>" },
    "within":                    { "replacement": null, "note": "Not in platformOS — build URLs manually" },
    "url_for_type":              { "replacement": null, "note": "Not in platformOS" },
    "url_for_vendor":            { "replacement": null, "note": "Not in platformOS" },
    "sort_by":                   { "replacement": null, "note": "Handle sorting via GraphQL query arguments" },
    "highlight":                 { "replacement": null, "note": "Not in platformOS — implement with JavaScript or custom logic" }
  },
  "tags": {
    "form":     { "replacement": "<form>", "note": "Use HTML <form> with <input type=\"hidden\" name=\"authenticity_token\" value=\"{{ context.authenticity_token }}\">. For PUT/DELETE add <input type=\"hidden\" name=\"_method\" value=\"put\">." },
    "endform":  { "replacement": "</form>", "note": "Use HTML </form>" },
    "section":  { "replacement": "render", "note": "Use {% render 'path/to/section' %}" },
    "schema":   { "replacement": null, "note": "platformOS uses YAML files in app/schema/ for data model definitions" },
    "endschema": { "replacement": null, "note": "platformOS uses YAML files in app/schema/" },
    "paginate": { "replacement": null, "note": "Manual pagination: assign page = context.params.page | default: 1 | plus: 0, then pass to GraphQL query" },
    "endpaginate": { "replacement": null, "note": "Manual pagination — no built-in paginate tag" },
    "layout":   { "replacement": null, "note": "Set layout in page frontmatter: layout: application (or omit for default)" }
  }
}
