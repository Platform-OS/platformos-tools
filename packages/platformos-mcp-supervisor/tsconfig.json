{
  "extends": "../../tsconfig.json",
  "include": ["./src/**/*.ts"],
  "exclude": ["./dist"],
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "tsBuildInfoFile": "dist/tsconfig.tsbuildinfo",
    "paths": {
      "@platformos/liquid-html-parser": ["../liquid-html-parser/src"],
      "@platformos/platformos-check-common": ["../platformos-check-common/src"],
      "@platformos/platformos-check-node": ["../platformos-check-node/src"],
      "@platformos/platformos-common": ["../platformos-common/src"],
      "@platformos/platformos-language-server-common": ["../platformos-language-server-common/src"],
      "@platformos/platformos-language-server-node": ["../platformos-language-server-node/src"]
    }
  },
  "references": [
    { "path": "../liquid-html-parser" },
    { "path": "../platformos-check-common" },
    { "path": "../platformos-check-node" },
    { "path": "../platformos-common" },
    { "path": "../platformos-language-server-common" },
    { "path": "../platformos-language-server-node" }
  ]
}
