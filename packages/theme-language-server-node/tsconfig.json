{
  "extends": "../../tsconfig.json",
  "include": ["./src/**/*.ts"],
  "exclude": ["./dist"],
  "compilerOptions": {
    "baseUrl": ".",
    "outDir": "dist",
    "rootDir": "src",
    "tsBuildInfoFile": "dist/tsconfig.tsbuildinfo",
    "paths": {
      "@platformos/theme-language-server-common": ["../theme-language-server-common/src"],
      "@platformos/theme-check-docs-updater": ["../theme-check-docs-updater/src"],
      "@platformos/theme-check-node": ["../theme-check-node/src"],
      "@platformos/platformos-common": ["../platformos-common/src"]
    }
  },
  "references": [
    { "path": "../theme-language-server-common" },
    { "path": "../theme-check-docs-updater" },
    { "path": "../theme-check-node" },
    { "path": "../platformos-common" }
  ]
