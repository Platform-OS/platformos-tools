{
  "name": "platformos-check-vscode",
  "author": "CP Clermont <cp.clermont@shopify.com>",
  "homepage": "https://github.com/Platform-OS/platformos-tools/tree/main/packages/vscode-extension#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Platform-OS/platformos-tools.git",
    "directory": "packages/vscode-extension"
  },
  "bugs": {
    "url": "https://github.com/Platform-OS/platformos-tools/issues"
  },
  "version": "1.0.0",
  "publisher": "platformOS",
  "private": true,
  "license": "SEE LICENSE IN LICENSE.md",
  "displayName": "platformOS Liquid v2",
  "description": "A complete developer experience for platformOS",
  "categories": [
    "Programming Languages",
    "Linters",
    "Language Packs"
  ],
  "keywords": [
    "liquid",
    "graphql",
    "platformos"
  ],
  "preview": false,
  "icon": "images/pos.jpg",
  "scripts": {
    "build": "yarn build:ci",
    "build:ci": "yarn build:extension && yarn build:language-config && yarn build:syntax",
    "build:extension": "webpack --mode production",
    "build:extension:dev": "webpack --mode development",
    "build:language-config": "ts-node scripts/make-language-configuration.ts",
    "build:syntax": "yarn --cwd ./syntaxes build",
    "build:ts": "true",
    "dev": "rimraf dist && yarn dev:watch",
    "dev:build": "webpack --mode development",
    "dev:syntax": "yarn --cwd ./syntaxes dev",
    "dev:watch": "webpack --mode development --watch",
    "dev:web": "yarn build && vscode-test-web --permission=clipboard-read --permission=clipboard-write --browserType=chromium --extensionDevelopmentPath=.",
    "format": "prettier --write 'src/**/*.{ts,js}'",
    "format:check": "prettier --check 'src/**/*.{js,ts}'",
    "lint": "eslint src --ext ts",
    "package": "vsce package --no-dependencies $npm_package_version",
    "postinstall": "yarn --cwd ./syntaxes install",
    "prebuild": "rimraf dist language-configuration.json",
    "preinstall": "sh scripts/fetch-syntaxes.sh",
    "pretest": "yarn run test:build && yarn run dev:build && yarn run lint",
    "publish:vsce": "vsce publish --no-dependencies $npm_package_version",
    "publish:ovsx": "ovsx publish --yarn",
    "test": "vitest",
    "test:build": "tsc -p . --outDir out",
    "test:watch": "tsc -p . -w --outDir out",
    "type-check": "tsc --noEmit"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "dependencies": {
    "@platformos/liquid-html-parser": "^2.9.0",
    "@platformos/prettier-plugin-liquid": "^1.10.0",
    "@platformos/theme-check-common": "^3.23.0",
    "@platformos/theme-language-server-browser": "^2.20.0",
    "@platformos/theme-language-server-common": "^2.20.0",
    "@platformos/theme-language-server-node": "^2.20.0",
    "prettier": "^2.6.2",
    "vscode-languageclient": "^8.1.0",
    "vscode-uri": "^3.0.8"
  },
  "devDependencies": {
    "@platformos/theme-check-docs-updater": "^3.23.0",
    "@types/glob": "^8.0.0",
    "@types/node": "^22",
    "@types/prettier": "^2.4.2",
    "@types/vscode": "^1.104.0",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "@vscode/test-electron": "^2.2.0",
    "@vscode/test-web": "^0.0.62",
    "@vscode/vsce": "^2.21.0",
    "ovsx": "^0.10.4",
    "chai": "^4.3.4",
    "eslint": "^8.28.0",
    "eslint-config-prettier": "^8.3.0",
    "rimraf": "^3.0.2",
    "vscode-test": "^1.3.0"
  },
  "activationEvents": [
    "workspaceContains:**/.theme-check.yml",
    "workspaceContains:**/*.liquid"
  ],
  "main": "./dist/node/extension.js",
  "browser": "./dist/browser/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "platformosLiquid.restart",
        "title": "Liquid Check: Restart Server"
      },
      {
        "command": "platformosLiquid.runChecks",
        "title": "Liquid Check: Run Checks"
      },
      {
        "command": "platformosLiquid.deadCode",
        "title": "Liquid Check: Find dead code"
      },
      {
        "command": "platformosLiquid.openLocation",
        "title": "Open document at location"
      }
    ],
    "configuration": {
      "title": "platformOS Liquid v2 | Syntax Highlighting & Linter by platformOS",
      "properties": {
        "platformosLiquid.trace.server": {
          "type": [
            "string"
          ],
          "description": "Traces the communication between the client and the server.",
          "default": "off",
          "enum": [
            "off",
            "messages",
            "verbose"
          ]
        },
        "platformosCheck.checkOnOpen": {
          "type": [
            "boolean"
          ],
          "description": "When true, theme check runs on file open.",
          "default": true
        },
        "platformosCheck.checkOnChange": {
          "type": [
            "boolean"
          ],
          "description": "When true, theme check runs on file change.",
          "default": true
        },
        "platformosCheck.checkOnSave": {
          "type": [
            "boolean"
          ],
          "description": "When true, theme check runs on file save.",
          "default": true
        },
        "platformosCheck.preloadOnBoot": {
          "type": [
            "boolean"
          ],
          "description": "When true, theme check preloads all the files from your theme for fast rename handling and theme graph generation.",
          "default": true
        }
      }
    },
    "views": {
      "explorer": [
        {
          "id": "shopify.themeGraph.references",
          "name": "References",
          "icon": "$(references)",
          "when": "shopify.themeGraph.references.enabled"
        },
        {
          "id": "shopify.themeGraph.dependencies",
          "name": "Dependencies",
          "icon": "$(outline-view-icon)",
          "when": "shopify.themeGraph.dependencies.enabled"
        }
      ]
    },
    "configurationDefaults": {
      "[liquid]": {
        "editor.formatOnType": true
      }
    },
    "jsonValidation": [
      {
        "fileMatch": [
          "assets/*.json",
          "config/*.json",
          "locales/*.json",
          "sections/*.json",
          "templates/**/*.json"
        ],
        "url": "./allowCommentsSchema.json"
      }
    ],
    "languages": [
      {
        "id": "liquid",
        "configuration": "./language-configuration.json",
        "aliases": [
          "Liquid",
          "liquid",
          "HTML Liquid"
        ],
        "extensions": [
          ".liquid"
        ]
      },
      {
        "id": "jsonc",
        "filenamePatterns": [
          "**/assets/*.json",
          "**/config/*.json",
          "**/locales/*.json",
          "**/sections/*.json",
          "**/templates/**/*.json"
        ]
      }
    ],
    "grammars": [
      {
        "language": "liquid",
        "scopeName": "text.html.liquid",
        "path": "./syntaxes/grammars/liquid.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.css": "css",
          "meta.embedded.block.js": "javascript"
        }
      },
      {
        "path": "./syntaxes/grammars/liquid-injection.tmLanguage.json",
        "scopeName": "liquid.injection",
        "embeddedLanguages": {
          "meta.object.liquid": "liquid",
          "meta.tag.liquid": "liquid"
        },
        "injectTo": [
          "text.html.liquid"
        ]
      }
    ]
  }
}
