{
  "name": "platformos-check-vscode",
  "author": "platformOS",
  "homepage": "https://github.com/Platform-OS/platformos-tools/tree/master/packages/vscode-extension#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Platform-OS/platformos-tools.git",
    "directory": "packages/vscode-extension"
  },
  "bugs": {
    "url": "https://github.com/Platform-OS/platformos-tools/issues"
  },
  "version": "0.3.2",
  "publisher": "platformOS",
  "private": true,
  "license": "SEE LICENSE IN LICENSE.md",
  "displayName": "platformOS Liquid v2",
  "description": "A complete developer experience for platformOS",
  "categories": [
    "Programming Languages",
    "Linters",
    "Language Packs"
  ],
  "keywords": [
    "platformOS",
    "liquid",
    "platformos-check",
    "graphql"
  ],
  "preview": false,
  "icon": "images/pos.jpg",
  "scripts": {
    "build": "yarn build:ci",
    "build:ci": "yarn build:extension && yarn build:language-config && yarn build:syntax",
    "build:extension": "webpack --mode production",
    "build:extension:dev": "webpack --mode development",
    "build:language-config": "ts-node scripts/make-language-configuration.ts",
    "build:syntax": "yarn --cwd ./syntaxes build",
    "build:ts": "true",
    "dev": "rimraf dist && yarn dev:watch",
    "dev:build": "webpack --mode development",
    "dev:syntax": "yarn --cwd ./syntaxes dev",
    "dev:watch": "webpack --mode development --watch",
    "dev:web": "yarn build && vscode-test-web --permission=clipboard-read --permission=clipboard-write --browserType=chromium --extensionDevelopmentPath=.",
    "format": "prettier --write 'src/**/*.{ts,js}'",
    "format:check": "prettier --check 'src/**/*.{js,ts}'",
    "lint": "eslint src --ext ts",
    "package": "vsce package --no-dependencies 0.3.2",
    "postinstall": "yarn --cwd ./syntaxes install",
    "prebuild": "rimraf dist language-configuration.json",
    "preinstall": "sh scripts/fetch-syntaxes.sh",
    "pretest": "yarn run test:build && yarn run dev:build && yarn run lint",
    "publish:vsce": "vsce publish --no-dependencies 0.3.2",
    "publish:ovsx": "ovsx publish --yarn",
    "test": "vitest",
    "test:build": "tsc -p . --outDir out",
    "test:watch": "tsc -p . -w --outDir out",
    "type-check": "tsc --noEmit"
  },
  "engines": {
    "vscode": "^1.109.0"
  },
  "dependencies": {
    "@platformos/liquid-html-parser": "^0.0.11",
    "@platformos/platformos-check-common": "0.0.12",
    "@platformos/platformos-language-server-browser": "0.0.12",
    "@platformos/platformos-language-server-common": "0.0.12",
    "@platformos/platformos-language-server-node": "0.0.12",
    "@platformos/prettier-plugin-liquid": "^0.0.11",
    "prettier": "^3.8.1",
    "vscode-languageclient": "^9.0.1",
    "vscode-uri": "^3.1.0"
  },
  "devDependencies": {
    "@platformos/platformos-check-docs-updater": "0.0.12",
    "@types/node": "^22",
    "@types/prettier": "^2.4.2",
    "@types/vscode": "^1.109.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vscode/test-electron": "^2.2.0",
    "@vscode/test-web": "^0.0.62",
    "@vscode/vsce": "^3.7.1",
    "chai": "^6.2.2",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "ovsx": "^0.10.9",
    "rimraf": "^6.1.3",
    "vscode-test": "^1.3.0"
  },
  "activationEvents": [
    "workspaceContains:**/.platformos-check.yml",
    "workspaceContains:**/*.liquid"
  ],
  "main": "./dist/node/extension.js",
  "browser": "./dist/browser/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "platformosLiquid.restart",
        "title": "Liquid Check: Restart Server"
      },
      {
        "command": "platformosLiquid.runChecks",
        "title": "Liquid Check: Run Checks"
      },
      {
        "command": "platformosLiquid.deadCode",
        "title": "Liquid Check: Find dead code"
      },
      {
        "command": "platformosLiquid.openLocation",
        "title": "Open document at location"
      }
    ],
    "configuration": {
      "title": "platformOS Liquid v2 | Syntax Highlighting & Linter by platformOS",
      "properties": {
        "platformosLiquid.trace.server": {
          "type": [
            "string"
          ],
          "description": "Traces the communication between the client and the server.",
          "default": "off",
          "enum": [
            "off",
            "messages",
            "verbose"
          ]
        },
        "platformosCheck.checkOnOpen": {
          "type": [
            "boolean"
          ],
          "description": "When true, platformOS check runs on file open.",
          "default": true
        },
        "platformosCheck.checkOnChange": {
          "type": [
            "boolean"
          ],
          "description": "When true, platformOS check runs on file change.",
          "default": true
        },
        "platformosCheck.checkOnSave": {
          "type": [
            "boolean"
          ],
          "description": "When true, platformOS check runs on file save.",
          "default": true
        },
        "platformosCheck.preloadOnBoot": {
          "type": [
            "boolean"
          ],
          "description": "When true, platformOS check preloads all the files from your app for fast rename handling and app graph generation.",
          "default": true
        }
      }
    },
    "views": {
      "explorer": [
        {
          "id": "platformos.graph.references",
          "name": "References",
          "icon": "$(references)",
          "when": "platformos.graph.references.enabled"
        },
        {
          "id": "platformos.graph.dependencies",
          "name": "Dependencies",
          "icon": "$(outline-view-icon)",
          "when": "platformos.graph.dependencies.enabled"
        }
      ]
    },
    "configurationDefaults": {
      "[liquid]": {
        "editor.formatOnType": true
      }
    },
    "jsonValidation": [
      {
        "fileMatch": [
          "assets/*.json",
          "config/*.json",
          "locales/*.json"
        ],
        "url": "./allowCommentsSchema.json"
      }
    ],
    "languages": [
      {
        "id": "liquid",
        "configuration": "./language-configuration.json",
        "aliases": [
          "Liquid",
          "liquid",
          "HTML Liquid"
        ],
        "extensions": [
          ".liquid"
        ]
      },
      {
        "id": "jsonc",
        "filenamePatterns": [
          "**/assets/*.json",
          "**/config/*.json",
          "**/locales/*.json"
        ]
      }
    ],
    "grammars": [
      {
        "language": "liquid",
        "scopeName": "text.html.liquid",
        "path": "./syntaxes/grammars/liquid.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.css": "css",
          "meta.embedded.block.js": "javascript"
        }
      },
      {
        "path": "./syntaxes/grammars/liquid-injection.tmLanguage.json",
        "scopeName": "liquid.injection",
        "embeddedLanguages": {
          "meta.object.liquid": "liquid",
          "meta.tag.liquid": "liquid"
        },
        "injectTo": [
          "text.html.liquid"
        ]
      }
    ]
  }
}
